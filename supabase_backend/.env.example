# ═══════════════════════════════════════════════════════════════
# KaptanlikApp - Supabase Backend Environment Variables
# ═══════════════════════════════════════════════════════════════
#
# Bu dosyayi .env olarak kopyalayin ve degerleri guncelleyin:
#   cp .env.example .env
#
# UYARI: .env dosyasini asla Git reposuna eklemeyin!
#        .gitignore'da .env oldugundan emin olun.
#
# ═══════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
POSTGRES_USER=supabase_admin
POSTGRES_DB=postgres

# ─────────────────────────────────────────────────────────────
# Supabase API URL ve Anahtarlar
# ─────────────────────────────────────────────────────────────
# SUPABASE_URL: PostgREST API endpoint (Kong uzerinden)
SUPABASE_URL=http://localhost:54321

# ANON_KEY: Anonim kullanıcı anahtarı (JWT)
# Supabase Studio'dan alabilir veya varsayilan degeri kullanabilirsiniz.
# Varsayilan (local):
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# SERVICE_ROLE_KEY: Servis rolu anahtari (tam yetki)
# Sadece sunucu tarafinda kullanilmali!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ─────────────────────────────────────────────────────────────
# JWT & Guvenlik
# ─────────────────────────────────────────────────────────────
# JWT_SECRET: JSON Web Token imzalama anahtari
# EN AZ 32 karakter uzunlugunda olmalidir!
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long

# Realtime ve diger servisler icin ek secret
SECRET_KEY_BASE=your-super-secret-key-base-with-at-least-64-characters-long-for-realtime

# ─────────────────────────────────────────────────────────────
# API & Site URL'leri
# ─────────────────────────────────────────────────────────────
# API_EXTERNAL_URL: Auth callback'ler icin dis URL
API_EXTERNAL_URL=http://localhost:54321

# SITE_URL: Frontend uygulama URL'si (Auth yonlendirmeleri icin)
SITE_URL=http://localhost:5173

# Ek yonlendirme URL'leri (virgul ile ayrilmis)
ADDITIONAL_REDIRECT_URLS=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# SMTP / E-posta
# ─────────────────────────────────────────────────────────────
# Local gelistirme icin gecersiz bir SMTP kullanilabilir
# veya gotrue MAILER_AUTOCONFIRM=true ile e-posta dogrulama devre disi birakilabilir

SMTP_ADMIN_EMAIL=admin@kaptanlik.app
SMTP_HOST=mail
SMTP_PORT=2500
SMTP_USER=mailadmin
SMTP_PASS=mailadmin
SMTP_SENDER_NAME=KaptanlikApp

# ─────────────────────────────────────────────────────────────
# Portlar (docker-compose.yml ile uyumlu olmali)
# ─────────────────────────────────────────────────────────────
KONG_HTTP_PORT=54321
KONG_HTTPS_PORT=54322
STUDIO_PORT=54323
DATABASE_PORT=5432
REALTIME_PORT=54329

# ─────────────────────────────────────────────────────────────
# Gelistirme Ayarlari
# ─────────────────────────────────────────────────────────────
# Log seviyesi: debug, info, warn, error
LOG_LEVEL=info

# Otomatik migration (gelistirme ortaminda true)
AUTO_MIGRATION=true

# Seed data yukleme (gelistirme ortaminda true)
AUTO_SEED=true
